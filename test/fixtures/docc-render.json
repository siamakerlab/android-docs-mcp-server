        {
          "type": "paragraph",
          "inlineContent": [
            { "type": "text", "text": "Create a custom view by declaring a type that conforms to the " },
            {
              "type": "reference",
              "identifier": "doc://com.apple.SwiftUI/documentation/SwiftUI/View",
              "isActive": true
            },
            { "type": "text", "text": " protocol. Implement the required " },
            { "type": "codeVoice", "code": "body" },
            { "type": "text", "text": " computed property to provide the content." }
          ]
        },
        {
          "type": "codeListing",
          "syntax": "swift",
          "code": [
            "struct MyView: View {",
            "    var body: some View {",
            "        Text(\"Hello, world!\")",
            "    }",
            "}"
          ]
        }
